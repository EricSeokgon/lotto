# SPEC-LOTTO-002 — 환경 변수 템플릿
#
# 실제 사용 시 이 파일을 `.env` 로 복사하여 값을 수정하세요.
# `.env` 파일은 `.gitignore` 에 등록되어 있어 Git 에 커밋되지 않습니다.
# `python-dotenv` 가 설치되어 있으면 lotto/config.py 가 자동으로 로드합니다.

# === collector.py: 동행복권 API ===
# 회차 조회 URL 템플릿. {drw_no} 가 회차 번호로 치환됩니다.
LOTTO_API_URL=https://www.dhlottery.co.kr/common.do?method=getLottoNumber&drwNo={drw_no}

# === main.py / web/data.py: 데이터 저장 디렉토리 ===
# CSV, JSON, history 파일이 저장되는 루트 디렉토리. 상대 또는 절대 경로.
LOTTO_DATA_DIR=data

# === web: 대시보드 바인딩 ===
LOTTO_WEB_HOST=127.0.0.1
LOTTO_WEB_PORT=8000

# === recommender.py: 추천 가중치 ===
# w_freq, w_recent, w_pair, w_consec 순서 (콤마 구분, 합계는 0보다 커야 함)
LOTTO_RECOMMENDER_WEIGHTS=0.4,0.3,0.2,0.1

# === web/routes/api.py: 백그라운드 수집 체크포인트 ===
# 몇 회차마다 중간 저장할지 (정수)
LOTTO_CHECKPOINT_INTERVAL=20

# === scraper.py: 블로그 크롤링 URL ===
# 1~1000회 / 1001회 이후 데이터 페이지
LOTTO_SCRAPER_URL_1=https://signalfire85.tistory.com/798
LOTTO_SCRAPER_URL_2=https://signalfire85.tistory.com/28
